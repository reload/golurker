<html>
  <head>
    <meta http-equiv="content-type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Go lurker</title>
    <script src="https://cdn.jsdelivr.net/npm/htmx.org@4.0.0-beta2/dist/htmx.min.js"></script>
    <link rel="stylesheet" href="/styles.css">
  </head>
<body>
<h1>Go lurker</h1>

<% sites.each_with_index do |site, index| %>
<div>
  <a href="https://<%= site.includes?("www.") ? site.gsub(/^www./, "www.go.") : "go.#{site}" %>"><%= site %></a> 
  <span hx-get="/check/<%= index %>/<%= timestamp %>" hx-trigger="load">
    Checking...
  </span>
</div>

<% end %>

</body>
</html>
